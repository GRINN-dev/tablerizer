# Test Environment Configuration
#
# For Docker (default — just run: npm run test:docker)
# No configuration needed, docker-compose.test.yml handles everything.
#
# For local PostgreSQL, export these variables before running npm test:

ROOT_DATABASE_URL="postgresql://postgres:postgres@localhost:5433/postgres"
DATABASE_NAME="tablerizer_test"
DATABASE_OWNER="tablerizer_owner"
DATABASE_OWNER_PASSWORD="test_owner_pass"
DATABASE_AUTHENTICATOR="tablerizer_authenticator"
DATABASE_AUTHENTICATOR_PASSWORD="test_auth_pass"
DATABASE_VISITOR="tablerizer_visitor"
